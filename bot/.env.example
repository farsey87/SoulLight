# ===== SoulLight Telegram Bot - Konfiguration =====
# Kopiere diese Datei als .env und trage deine echten Werte ein:
#   copy .env.example .env

# 1) Bot-Token von @BotFather
BOT_TOKEN=DEIN_BOT_TOKEN_HIER

# 2) Gruppen-IDs (Rechtsklick auf Gruppe → "Gruppen-ID kopieren" oder /chatid im Bot)
FREE_GROUP_ID=-1001234567890
PREMIUM_GROUP_ID=-1001234567891
VIP_GROUP_ID=-1001234567892

# 3) Deine Admin-User-ID (schreibe @userinfobot an, um deine ID zu erfahren)
ADMIN_USER_ID=123456789

# 4) Website-URL
WEBSITE_URL=https://farsey87.github.io/SoulLight

# 5) Buchungslink (Cal.com oder Calendly)
BOOKING_URL=https://cal.com/soullight

# 6) Stripe Payment-Links (optional - erstelle sie in deinem Stripe-Dashboard)
STRIPE_LINK_PREMIUM=https://buy.stripe.com/DEIN_PREMIUM_LINK
STRIPE_LINK_ERWACHEN=https://buy.stripe.com/DEIN_ERWACHEN_LINK
STRIPE_LINK_BEFREIUNG=https://buy.stripe.com/DEIN_BEFREIUNG_LINK
STRIPE_LINK_SEELENREISE=https://buy.stripe.com/DEIN_SEELENREISE_LINK
